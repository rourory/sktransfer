// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelegramNotificationReceiver {
  id            String    @id @default(cuid())
  telegramId    String    @unique
  createdAt     DateTime  @default(now())
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  avatar    String?   
  bio       String?   
  articles  Article[]
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique // Единый URL для всех языков (например, "sanatorii")
  image         String?   // Обложка категории
  
  // Локализованные названия
  nameRu        String
  nameEn        String
  nameZh        String

  // Локализованные описания
  descriptionRu String?   @db.Text
  descriptionEn String?   @db.Text
  descriptionZh String?   @db.Text

  showInFooter  Boolean   @default(false)
  
  articles      Article[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Article {
  id                String    @id @default(cuid())
  slug              String    @unique // ЧПУ URL статьи
  
  // Локализованные заголовки (H1)
  titleRu           String
  titleEn           String
  titleZh           String
  
  // Локализованный контент с плейсхолдерами {0}, {1}...
  contentRu         String    @db.Text
  contentEn         String    @db.Text
  contentZh         String    @db.Text
  
  // Локализованные краткие описания
  excerptRu         String    @db.Text
  excerptEn         String    @db.Text
  excerptZh         String    @db.Text
  
  // Локализованные SEO-теги
  metaTitleRu       String?
  metaTitleEn       String?
  metaTitleZh       String?
  metaDescriptionRu String?
  metaDescriptionEn String?
  metaDescriptionZh String?
  
  // Изображения
  coverImage        String?   // Главное фото
  images            String?   @db.Text // JSON массив строк:["url1", "url2"]
  
  imageAltRu        String?
  imageAltEn        String?
  imageAltZh        String?
  
  isPublished       Boolean   @default(true)
  publishedAt       DateTime? @default(now())
  
  categoryId        String
  category          Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  authorId          String?
  author            User?     @relation(fields: [authorId], references: [id])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([slug])
  @@index([categoryId])
}

model Visitor {
  id        String   @id @default(cuid())
  hash      String   // Анонимный хэш (IP + UserAgent + Date)
  dateStr   String   // Дата в формате YYYY-MM-DD
  createdAt DateTime @default(now())

  // Составной уникальный ключ: один хэш может быть записан только 1 раз в день
  @@unique([hash, dateStr]) 
  @@index([dateStr]) // Индекс для быстрого построения графиков
}

model Tariff {
  id         String   @id @default(cuid())
  key        String   @unique // ключ тарифа: 'standard', 'comfort', 'business', 'minivan', 'vip', 'minibus'
  pricePerKm Float    // Стоимость за 1 км (например, 1.3)
  imageUrl   String   // Путь к картинке (например, '/tariffs/standard.webp')
  isActive   Boolean  @default(true) // Возможность скрыть тариф временно
  order      Int      @default(0) // Для сортировки вывода (0, 1, 2...)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TransferRoute {
  id                String   @id @default(cuid())
  slug              String   @unique // "minsk-grodno", "minsk-naroch", "aeroport-minsk-2"
  
  // Откуда → Куда (для SEO и отображения)
  fromSlug          String
  fromNameRu        String
  fromNameEn        String
  fromNameZh        String?
  toSlug            String
  toNameRu          String
  toNameEn          String
  toNameZh          String?

  additionalContentRu String?
  additionalContentEn String?
  additionalContentZh String?
  
  // Данные маршрута (будут использоваться для предзаполнения)
  distanceKm        Float
  durationMin       Int?      // пример: 200 минут
  fromLat           Float?
  fromLon           Float?
  toLat             Float?
  toLon             Float?
  
  // Флаги для фильтров и популярности
  isPopular         Boolean  @default(false)
  isAirport         Boolean  @default(false)
  isInternational   Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
  @@index([fromSlug, toSlug])
  @@index([isPopular])
}

model AirportTariff {
  id          String   @id @default(cuid())
  tariffKey   String   @unique  // Системный ключ (standard, comfort...)
  price       Float    // Цена в BYN
  
  // Локализованные названия тарифа (Стандарт, Standard, 标准)
  nameRu      String
  nameEn      String
  nameZh      String?

  // Локализованные особенности (через запятую)
  featuresRu  String   
  featuresEn  String
  featuresZh  String?
  
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}